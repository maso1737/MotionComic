  "events": [
    { "_c": "① 環境変化: P1がカチッ。amountは1回のみ→以後ホールド。mode切替はdiscreteで多重可（player挙動制約）。",
      "at": [0.02, 0.16], "target": "P1",
      "set": { "deform.amount": 0.95 }, "easing": "snap_comic" },

    { "_c": "② 雨傘姉が張り切り前へ（y/scaleは姉専用・1回）",
      "at": [0.15, 0.30], "target": "L_ane",
      "set": { "transform.y": 0, "transform.scale": 1.05 }, "easing": "snap_comic" },

    { "_c": "③ 別問題: 守りすぎで空気が翳る（核=semantic_shift。波及はD2b汎用化待ち）",
      "at": [0.30, 0.46], "type": "semantic_shift", "target": "world.air", "value": "陰" },
    { "_c": "③ P1が縮こまる: mode→round（discrete・amountは①保持値0.95を流用）",
      "at": [0.30, 0.32], "target": "P1", "set": { "deform.mode": "round" } },

    { "_c": "④ 位置変更: 妹が光を取りに寄る（x/y専用・1回）",
      "at": [0.46, 0.62], "target": "L_imouto",
      "set": { "transform.x": -150, "transform.y": 40 }, "easing": "paper_soft" },
    { "_c": "④ 末っ子が隙間へ（x/y専用・1回）",
      "at": [0.46, 0.62], "target": "L_sue",
      "set": { "transform.x": 130, "transform.y": -60 }, "easing": "wobble_child" },
    { "_c": "④ 兄がわずかに傾き譲る（rot専用・1回）",
      "at": [0.46, 0.62], "target": "L_kakashi",
      "set": { "transform.rot": -4 }, "easing": "float_memory" },
    { "_c": "④ P2が譲ってたわむ（P2.amount専用・1回→ホールド）",
      "at": [0.46, 0.62], "target": "P2",
      "set": { "deform.amount": 0.7 }, "easing": "paper_soft" },

    { "_c": "⑤ 一瞬ちょうどいい＝凪（核=semantic_shift。D2b波及待ち）",
      "at": [0.60, 0.68], "type": "semantic_shift", "target": "world.air", "value": "凪" },
    { "_c": "⑤ moment: 撮影処理が抜ける素の一瞬・無音・微粒子(L_kira)・静止",
      "at": [0.615, 0.665], "type": "moment",
      "set": { "post.grain": 0, "audio.mute": true, "scroll.snap": true } },

    { "_c": "⑥ 次の風で崩壊: P1がばね揺れへ（mode discrete・amount①保持値で振れる）",
      "at": [0.67, 0.69], "target": "P1", "set": { "deform.mode": "spring" } },
    { "_c": "⑥ P2もばね揺れへ（mode discrete）",
      "at": [0.69, 0.71], "target": "P2", "set": { "deform.mode": "spring" } },
    { "_c": "⑥ 雨傘姉が風に流される（x/rot専用・②と別キー・1回）",
      "at": [0.67, 0.86], "target": "L_ane",
      "set": { "transform.x": 290, "transform.rot": -24 }, "easing": "snap_comic" },
    { "_c": "⑥ 日傘妹が煽られる（rot専用・④と別キー・1回）",
      "at": [0.70, 0.90], "target": "L_imouto",
      "set": { "transform.rot": 16 }, "easing": "wobble_child" },
    { "_c": "⑥ 撮影が乱れる: ファイル内唯一のpost数値イベント（各キー1回・安全）",
      "at": [0.67, 0.88], "target": "post",
      "set": { "chromatic": 0.16, "vignette": 0.30,
               "color_shift.r": 1.0, "color_shift.b": 1.0 }, "easing": "snap_comic" }
  ],

